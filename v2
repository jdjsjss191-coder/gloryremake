        Text=table.concat(parts,' <font color="rgb(50,50,70)">|</font> '),
        TextColor3=T.TextPri,TextSize=12,Font=Enum.Font.GothamMedium,
        TextXAlignment=Enum.TextXAlignment.Left,
    },wFrame)

    -- auto-resize
    local function resize()
        local w=txsz(wLbl.Text:gsub('<[^>]+>',''),12,Enum.Font.GothamMedium).X+20
        tw(wFrame,{Size=UDim2.new(0,w,0,26)},.15)
    end
    resize()

    local wt={}
    function wt:Update(p)
        wLbl.Text=table.concat(p,' <font color="rgb(50,50,70)">|</font> ')
        resize()
    end
    function wt:Toggle()
        wFrame.Visible=not wFrame.Visible
    end
    return wt
end

-- ── CONFIG SYSTEM ────────────────────────────────────────────────────────────
function VantaUI:SaveConfig(name)
    local t={}
    for k,v in pairs(self.flags) do
        if typeof(v)=="boolean" then t[k]=v
        elseif typeof(v)=="number" then t[k]=v
        elseif typeof(v)=="string" then t[k]=v
        elseif typeof(v)=="EnumItem" then t[k]=tostring(v)
        elseif typeof(v)=="Color3" then t[k]={math.floor(v.R*255),math.floor(v.G*255),math.floor(v.B*255)}
        end
    end
    local ok,hs=pcall(function() return game:GetService("HttpService"):JSONEncode(t) end)
    if ok then
        pcall(function()
            if not isfolder("vanta") then makefolder("vanta") end
            writefile("vanta/"..name..".json",hs)
        end)
    end
end

function VantaUI:LoadConfig(name)
    local ok,data=pcall(function()
        local raw=readfile("vanta/"..name..".json")
        return game:GetService("HttpService"):JSONDecode(raw)
    end)
    if not ok or not data then return end
    for k,v in pairs(data) do
        local setter=self._setters[k]
        if setter then
            if type(v)=="table" and #v==3 then
                setter(Color3.fromRGB(v[1],v[2],v[3]))
            elseif type(v)=="string" and v:find("Enum.") then
                pcall(function()
                    local parts=v:split(".")
                    setter(Enum[parts[2]][parts[3]])
                end)
            else setter(v) end
        end
    end
end

function VantaUI:ListConfigs()
    local out={}
    pcall(function()
        if isfolder("vanta") then
            for _,f in ipairs(listfiles("vanta")) do
                table.insert(out,(f:gsub("vanta\\",""):gsub("vanta/",""):gsub("%.json","")))
            end
        end
    end)
    return out
end

