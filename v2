        BackgroundColor3=T.BG3,BackgroundTransparency=.15,BorderSizePixel=0,
    },wGui)
    corner(6,wFrame); stroke(T.Border,1,wFrame); shadow(wFrame,12,.7)

    -- accent left bar
    local ab=mk("Frame",{Size=UDim2.new(0,3,1,-8),Position=UDim2.new(0,0,0,4),
        BackgroundColor3=self.accent,BorderSizePixel=0},wFrame)
    corner(2,ab)

    local wLbl=mk("TextLabel",{
