-- ── UTILITY ──────────────────────────────────────────────────────────────────
local function tw(obj, props, t, sty, dir, cb)
    local a = TS:Create(obj, TweenInfo.new(t or .2, sty or Enum.EasingStyle.Quart, dir or Enum.EasingDirection.Out), props)
    a:Play(); if cb then a.Completed:Connect(cb) end; return a
end
local function sp(obj, props, cb)
    local a = TS:Create(obj, TweenInfo.new(.35, Enum.EasingStyle.Back, Enum.EasingDirection.Out), props)
    a:Play(); if cb then a.Completed:Connect(cb) end; return a
end
local function mk(cls, p, par)
    local o = Instance.new(cls)
    for k,v in pairs(p or {}) do pcall(function() o[k]=v end) end
    if par then o.Parent = par end; return o
end
local function corner(r, par) return mk("UICorner",{CornerRadius=UDim.new(0,r or 6)},par) end
local function stroke(c, th, par)
    return mk("UIStroke",{Color=c or T.Border,Thickness=th or 1,ApplyStrokeMode=Enum.ApplyStrokeMode.Border},par)
end
local function pad(l,r,t,b,par)
    return mk("UIPadding",{PaddingLeft=UDim.new(0,l or 0),PaddingRight=UDim.new(0,r or 0),
        PaddingTop=UDim.new(0,t or 0),PaddingBottom=UDim.new(0,b or 0)},par)
end
local function list(dir,p,par)
    return mk("UIListLayout",{FillDirection=dir or Enum.FillDirection.Vertical,
        SortOrder=Enum.SortOrder.LayoutOrder,Padding=UDim.new(0,p or 0)},par)
end
local function grad(c0,c1,rot,par)
    return mk("UIGradient",{Color=ColorSequence.new(c0,c1),Rotation=rot or 90},par)
end
local function shadow(par, sz, tr)
    return mk("ImageLabel",{
        Size=UDim2.new(1,sz or 40,1,sz or 40),
        Position=UDim2.new(0,-(sz or 40)/2,0,-(sz or 40)/2),
        BackgroundTransparency=1,
        Image="rbxassetid://6014261993",
        ImageColor3=Color3.new(0,0,0),
        ImageTransparency=tr or .55,
        ScaleType=Enum.ScaleType.Slice,
        SliceCenter=Rect.new(49,49,450,450),
        ZIndex=-1,
    },par)
end
local function txsz(txt,sz,fnt)
    return TXS:GetTextSize(txt,sz or 13,fnt or Enum.Font.GothamMedium,Vector2.new(9999,9999))
end
local function lerp(a,b,t) return a+(b-a)*t end

