        -- ── COLORPICKER (standalone row) ─────────────────────────────────
        function sec:Colorpicker(o, _parentRow)
            o=o or {}
            local nm=o.name or "Color"; local ptr=o.pointer or nm
            local def=o.default or Color3.fromRGB(255,255,255)
            local cb=o.callback or function()end
            lib.flags[ptr]=def

            local r=_parentRow or baseRow(30)
            if not _parentRow then rowHover(r) end

            -- color swatch
            local swatch=mk("Frame",{
                Size=UDim2.new(0,18,0,12),Position=UDim2.new(1,-(_parentRow and 8 or 44),.5,-6),
                BackgroundColor3=def,BorderSizePixel=0,ZIndex=5,
            },r)
            corner(3,swatch); stroke(T.Border,1,swatch)

            if not _parentRow then
                mk("TextLabel",{Size=UDim2.new(1,-50,1,0),Position=UDim2.new(0,10,0,0),
                    BackgroundTransparency=1,Text=nm,TextColor3=T.TextSub,
                    TextSize=12,Font=Enum.Font.GothamMedium,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=4},r)
            end

            -- picker popup
            local popup=mk("Frame",{
                Size=UDim2.new(0,180,0,0),
                Position=UDim2.new(1,-182,1,4),
                BackgroundColor3=T.BG3,BorderSizePixel=0,
                ClipsDescendants=false,ZIndex=20,Visible=false,
            },r)
            corner(8,popup); stroke(T.BorderLt,1,popup); shadow(popup,16,.7)

            local popOpen=false
            local function closePopup()
                popOpen=false
                tw(popup,{Size=UDim2.new(0,180,0,0)},.18,Enum.EasingStyle.Quart,Enum.EasingDirection.In,function()
                    popup.Visible=false
                end)
            end
            local function openPopup()
                popOpen=true; popup.Visible=true
                tw(popup,{Size=UDim2.new(0,180,0,168)},.25,Enum.EasingStyle.Back,Enum.EasingDirection.Out)
            end

            -- saturation/value field
            local sv=mk("ImageLabel",{
                Size=UDim2.new(1,-8,0,110),Position=UDim2.new(0,4,0,4),
                BackgroundColor3=def,BorderSizePixel=0,
                Image="rbxassetid://8630797271",ZIndex=21,
            },popup)
            corner(4,sv); stroke(T.Border,1,sv)

            local svPicker=mk("Frame",{Size=UDim2.new(0,8,0,8),
                BackgroundColor3=Color3.fromRGB(255,255,255),BorderSizePixel=0,ZIndex=22},sv)
            corner(4,svPicker)

            -- hue bar
            local hueBar=mk("ImageLabel",{
                Size=UDim2.new(0,12,0,110),Position=UDim2.new(1,-16,0,4),
                BackgroundColor3=Color3.fromRGB(255,0,0),BorderSizePixel=0,
                Image="rbxassetid://8630799159",ScaleType=Enum.ScaleType.Crop,ZIndex=21,
            },popup)
            corner(3,hueBar); stroke(T.Border,1,hueBar)

            local huePicker=mk("Frame",{Size=UDim2.new(1,0,0,2),
                BackgroundColor3=Color3.fromRGB(255,255,255),BorderSizePixel=0,ZIndex=22},hueBar)

            -- hex input
            local hexBox=mk("TextBox",{
                Size=UDim2.new(1,-8,0,20),Position=UDim2.new(0,4,0,118),
                BackgroundColor3=T.BG2,BackgroundTransparency=.3,
                Text=string.format("#%02X%02X%02X",def.R*255,def.G*255,def.B*255),
                TextColor3=T.TextPri,TextSize=11,Font=Enum.Font.GothamMedium,
                PlaceholderText="#RRGGBB",ZIndex=21,BorderSizePixel=0,
            },popup)
            corner(4,hexBox); stroke(T.Border,1,hexBox)
            pad(6,0,0,0,hexBox)

            -- rainbow toggle
            local rbRow=mk("TextButton",{
                Size=UDim2.new(1,-8,0,20),Position=UDim2.new(0,4,0,142),
                BackgroundColor3=T.BG2,BackgroundTransparency=.3,
                Text="🌈  Rainbow",TextColor3=T.TextSub,TextSize=11,
                Font=Enum.Font.GothamMedium,AutoButtonColor=false,ZIndex=21,
            },popup)
            corner(4,rbRow)

            local hue,sat,val2=def:ToHSV()
            local rainbow=false; local rbConn

            local function applyColor(c)
                lib.flags[ptr]=c; swatch.BackgroundColor3=c
                sv.BackgroundColor3=Color3.fromHSV(hue,1,1)
                hexBox.Text=string.format("#%02X%02X%02X",math.floor(c.R*255+.5),math.floor(c.G*255+.5),math.floor(c.B*255+.5))
                cb(c)
            end
            local function rebuild()
                local c=Color3.fromHSV(hue,sat,val2)
                svPicker.Position=UDim2.new(sat,-4,1-val2,-4)
                huePicker.Position=UDim2.new(0,0,1-hue,-1)
                applyColor(c)
            end
            rebuild()

            -- sv drag
            local svDrag=false
            sv.InputBegan:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 then
                    svDrag=true
                    sat=math.clamp((i.Position.X-sv.AbsolutePosition.X)/sv.AbsoluteSize.X,0,1)
                    val2=1-math.clamp((i.Position.Y-sv.AbsolutePosition.Y)/sv.AbsoluteSize.Y,0,1)
                    rebuild()
                end
            end)
            sv.InputEnded:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 then svDrag=false end
            end)
            UIS.InputChanged:Connect(function(i)
                if svDrag and i.UserInputType==Enum.UserInputType.MouseMovement then
                    sat=math.clamp((i.Position.X-sv.AbsolutePosition.X)/sv.AbsoluteSize.X,0,1)
                    val2=1-math.clamp((i.Position.Y-sv.AbsolutePosition.Y)/sv.AbsoluteSize.Y,0,1)
                    rebuild()
                end
            end)

            -- hue drag
            local hueDrag=false
            hueBar.InputBegan:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 then
                    hueDrag=true
                    hue=1-math.clamp((i.Position.Y-hueBar.AbsolutePosition.Y)/hueBar.AbsoluteSize.Y,0,1)
                    rebuild()
                end
            end)
            hueBar.InputEnded:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 then hueDrag=false end
            end)
            UIS.InputChanged:Connect(function(i)
                if hueDrag and i.UserInputType==Enum.UserInputType.MouseMovement then
                    hue=1-math.clamp((i.Position.Y-hueBar.AbsolutePosition.Y)/hueBar.AbsoluteSize.Y,0,1)
                    rebuild()
                end
            end)

            -- hex input
            hexBox.FocusLost:Connect(function()
                local hex=hexBox.Text:gsub("#","")
                if #hex==6 then
                    local r2=tonumber(hex:sub(1,2),16)
                    local g2=tonumber(hex:sub(3,4),16)
                    local b2=tonumber(hex:sub(5,6),16)
                    if r2 and g2 and b2 then
                        local c=Color3.fromRGB(r2,g2,b2)
                        hue,sat,val2=c:ToHSV(); rebuild()
                    end
                end
            end)

            -- rainbow
            rbRow.MouseButton1Click:Connect(function()
                rainbow=not rainbow
                tw(rbRow,{TextColor3=rainbow and lib.accent or T.TextSub},.15)
                if rainbow then
                    rbConn=RS.Heartbeat:Connect(function()
                        if not rainbow then rbConn:Disconnect(); return end
                        hue=(hue+.002)%1; rebuild()
                    end)
                elseif rbConn then rbConn:Disconnect() end
            end)

            -- open/close on swatch click
            local swBtn=mk("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=6},swatch)
            swBtn.MouseButton1Click:Connect(function()
                if popOpen then closePopup() else openPopup() end
            end)

            local s={}
            function s:Set(c)
                hue,sat,val2=c:ToHSV(); rebuild()
            end
            lib._setters[ptr]=function(v) s:Set(v) end
            return s
        end

        return sec
    end -- end Section

    return tab
end -- end Tab

-- ── TAB SWITCH ───────────────────────────────────────────────────────────────
function VantaUI:_switch(target)
    if self._busy or target._on then return end
    self._busy=true

    for _,tab in pairs(self._tabs) do
        if tab._on and tab~=target then
            tab._on=false
            tw(tab._btn,{TextColor3=T.TextDim},.18)
            tw(tab._frame,{Position=UDim2.new(-1,0,0,0)},.2,Enum.EasingStyle.Quart,Enum.EasingDirection.In,function()
                tab._frame.Visible=false
                tab._frame.Position=UDim2.new(0,0,0,0)
            end)
        end
    end

    target._on=true
    target._frame.Visible=true
    target._frame.Position=UDim2.new(1,0,0,0)
    tw(target._frame,{Position=UDim2.new(0,0,0,0)},.26,Enum.EasingStyle.Quart,Enum.EasingDirection.Out)
    tw(target._btn,{TextColor3=self.accent},.18)

    -- slide indicator to button
    task.defer(function()
        local ba=target._btn.AbsolutePosition
        local ta=self._tabbar.AbsolutePosition
        local rx=ba.X-ta.X-8
        tw(self._ind,{
            Position=UDim2.new(0,rx,1,-2),
            Size=UDim2.new(0,target._btn.AbsoluteSize.X,0,2),
        },.22,Enum.EasingStyle.Quart,Enum.EasingDirection.Out)
    end)

    task.delay(.3,function() self._busy=false end)
end

