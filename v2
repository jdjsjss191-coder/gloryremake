function VantaUI.Notify(opts)
    opts = opts or {}
    local title    = opts.title    or "Vanta"
    local desc     = opts.desc     or ""
    local duration = opts.duration or 3.5
    local ntype    = opts.type     or "info"
    local acol = ({info=T.Accent,success=T.Green,error=T.Red,warn=T.Yellow})[ntype] or T.Accent
    local ico  = ({info="ℹ",success="✓",error="✕",warn="⚠"})[ntype] or "ℹ"

    local card = mk("Frame",{
        Size=UDim2.new(1,0,0,66),
        BackgroundColor3=T.BG3,
        Position=UDim2.new(1,10,0,0),
        ClipsDescendants=true,
    },_notifStack)
    corner(8,card); stroke(T.Border,1,card); shadow(card,18,.65)

    -- left accent bar
    local bar=mk("Frame",{Size=UDim2.new(0,3,1,-12),Position=UDim2.new(0,0,0,6),
        BackgroundColor3=acol,BorderSizePixel=0},card); corner(2,bar)

    -- progress line
    local prog=mk("Frame",{Size=UDim2.new(1,0,0,2),Position=UDim2.new(0,0,1,-2),
        BackgroundColor3=acol,BorderSizePixel=0},card)

    -- icon badge
    local ibadge=mk("Frame",{Size=UDim2.new(0,26,0,26),Position=UDim2.new(0,12,0,20),
        BackgroundColor3=acol,BackgroundTransparency=0.82,BorderSizePixel=0},card)
    corner(6,ibadge)
    mk("TextLabel",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
        Text=ico,TextColor3=acol,TextSize=13,Font=Enum.Font.GothamBold,
        TextXAlignment=Enum.TextXAlignment.Center},ibadge)

    mk("TextLabel",{Size=UDim2.new(1,-52,0,18),Position=UDim2.new(0,46,0,8),
        BackgroundTransparency=1,Text=title,TextColor3=T.TextPri,
        TextSize=13,Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Left},card)
    mk("TextLabel",{Size=UDim2.new(1,-52,0,28),Position=UDim2.new(0,46,0,26),
        BackgroundTransparency=1,Text=desc,TextColor3=T.TextSub,
        TextSize=11,Font=Enum.Font.Gotham,TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true},card)

    -- slide in
    sp(card,{Position=UDim2.new(0,0,0,0)})
    tw(prog,{Size=UDim2.new(0,0,0,2)},duration,Enum.EasingStyle.Linear)

    task.delay(duration,function()
        tw(card,{Position=UDim2.new(1,10,0,0)},.22,Enum.EasingStyle.Quart,Enum.EasingDirection.In,function()
            card:Destroy()
        end)
    end)
end

-- ── CONSTRUCTOR ──────────────────────────────────────────────────────────────
function VantaUI.new(opts)
    opts = opts or {}
    local self = setmetatable({},VantaUI)
    self.flags    = {}
    self._setters = {}
    self.toggled  = true
    self.accent   = opts.accent    or T.Accent
    self._title   = opts.title     or "Vanta"
    self._sub     = opts.subtitle  or ".cc"
    self._sx      = opts.sizeX     or 600
    self._sy      = opts.sizeY     or 480
    self._tabs    = {}
    self._curTab  = nil
    self._busy    = false

    self._gui = mk("ScreenGui",{
        Name="VantaUI",ResetOnSpawn=false,
        ZIndexBehavior=Enum.ZIndexBehavior.Sibling,IgnoreGuiInset=true,
    })
    pcall(function() self._gui.Parent=CG end)
    if not self._gui.Parent then self._gui.Parent=PLS.LocalPlayer:WaitForChild("PlayerGui") end

    self:_build()
    self:_drag()
    self:_hotkey(opts.key or Enum.KeyCode.RightShift)
    self:_open()
    return self
end

-- ── WINDOW BUILD ─────────────────────────────────────────────────────────────
function VantaUI:_build()
    local sx,sy = self._sx, self._sy

    self._holder = mk("Frame",{
        Size=UDim2.new(0,sx,0,sy),
        Position=UDim2.new(.5,-sx/2,.5,-sy/2),
        BackgroundTransparency=1,
    },self._gui)
    shadow(self._holder,44,.58)

    self._win = mk("Frame",{
        Size=UDim2.new(1,0,1,0),
        BackgroundColor3=T.BG,
        BorderSizePixel=0,
        ClipsDescendants=true,
    },self._holder)
    corner(10,self._win)
    stroke(T.Border,1,self._win)
    grad(T.BG2,T.BG,135,self._win)

    -- ── title bar
    self._tbar = mk("Frame",{
        Size=UDim2.new(1,0,0,46),
        BackgroundColor3=T.BG2,
        BorderSizePixel=0,ZIndex=5,
    },self._win)
    grad(T.BG3,T.BG2,180,self._tbar)

    -- bottom border
    mk("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),
        BackgroundColor3=T.Border,BorderSizePixel=0,ZIndex=6},self._tbar)

    -- animated accent glow line
    self._glow = mk("Frame",{Size=UDim2.new(0,0,0,2),Position=UDim2.new(0,0,1,-1),
        BackgroundColor3=self.accent,BorderSizePixel=0,ZIndex=7},self._tbar)
    corner(1,self._glow)
    task.delay(.08,function()
        tw(self._glow,{Size=UDim2.new(.38,0,0,2)},.7,Enum.EasingStyle.Quart)
    end)

    -- logo dot
    local dot=mk("Frame",{Size=UDim2.new(0,7,0,7),Position=UDim2.new(0,14,.5,-3.5),
        BackgroundColor3=self.accent,BorderSizePixel=0,ZIndex=6},self._tbar)
    corner(4,dot)
    -- pulse dot
    task.spawn(function()
        while self._gui.Parent do
            tw(dot,{BackgroundTransparency=0.5},.8,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut)
            task.wait(.85)
            tw(dot,{BackgroundTransparency=0},.8,Enum.EasingStyle.Sine,Enum.EasingDirection.InOut)
            task.wait(.85)
        end
    end)

    -- title
    mk("TextLabel",{
        Size=UDim2.new(0,220,1,0),Position=UDim2.new(0,26,0,0),
        BackgroundTransparency=1,RichText=true,
        Text='<font color="rgb(228,228,240)">'..self._title..'</font>'
            ..'<font color="rgb(80,140,255)">'..self._sub..'</font>',
        TextSize=15,Font=Enum.Font.GothamBold,
        TextXAlignment=Enum.TextXAlignment.Left,ZIndex=6,
    },self._tbar)

    -- version tag
    mk("TextLabel",{
        Size=UDim2.new(0,80,1,0),Position=UDim2.new(1,-120,0,0),
        BackgroundTransparency=1,Text="v2.0",
        TextColor3=T.TextDim,TextSize=11,Font=Enum.Font.Gotham,
        TextXAlignment=Enum.TextXAlignment.Right,ZIndex=6,
    },self._tbar)

    -- close btn
    local cbtn=mk("TextButton",{
        Size=UDim2.new(0,26,0,26),Position=UDim2.new(1,-36,.5,-13),
        BackgroundColor3=Color3.fromRGB(200,55,55),BackgroundTransparency=.65,
        Text="✕",TextColor3=Color3.fromRGB(255,255,255),TextSize=11,
        Font=Enum.Font.GothamBold,ZIndex=7,AutoButtonColor=false,
    },self._tbar)
    corner(6,cbtn)
    cbtn.MouseEnter:Connect(function() tw(cbtn,{BackgroundTransparency=.1},.12) end)
    cbtn.MouseLeave:Connect(function() tw(cbtn,{BackgroundTransparency=.65},.12) end)
    cbtn.MouseButton1Click:Connect(function() self:Toggle() end)

    -- ── tab bar
    self._tabbar = mk("Frame",{
        Size=UDim2.new(1,0,0,34),Position=UDim2.new(0,0,0,46),
        BackgroundColor3=T.BG2,BorderSizePixel=0,ZIndex=5,ClipsDescendants=false,
    },self._win)
    mk("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),
        BackgroundColor3=T.Border,BorderSizePixel=0,ZIndex=6},self._tabbar)

    self._tabbtns = mk("Frame",{
        Size=UDim2.new(1,-16,1,0),Position=UDim2.new(0,8,0,0),
        BackgroundTransparency=1,ZIndex=6,
    },self._tabbar)
    list(Enum.FillDirection.Horizontal,4,self._tabbtns)

    -- sliding underline indicator
    self._ind = mk("Frame",{
        Size=UDim2.new(0,50,0,2),Position=UDim2.new(0,0,1,-2),
        BackgroundColor3=self.accent,BorderSizePixel=0,ZIndex=8,
    },self._tabbar)
    corner(1,self._ind)

    -- ── content
    self._content = mk("Frame",{
        Size=UDim2.new(1,0,1,-80),Position=UDim2.new(0,0,0,80),
        BackgroundTransparency=1,ClipsDescendants=true,ZIndex=3,
    },self._win)
end

-- ── DRAG ─────────────────────────────────────────────────────────────────────
function VantaUI:_drag()
    local drag,ds,sp2
    self._tbar.InputBegan:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then
            drag=true; ds=i.Position; sp2=self._holder.Position
        end
    end)
    self._tbar.InputEnded:Connect(function(i)
        if i.UserInputType==Enum.UserInputType.MouseButton1 then drag=false end
    end)
    UIS.InputChanged:Connect(function(i)
        if drag and i.UserInputType==Enum.UserInputType.MouseMovement then
            local d=i.Position-ds
            self._holder.Position=UDim2.new(sp2.X.Scale,sp2.X.Offset+d.X,sp2.Y.Scale,sp2.Y.Offset+d.Y)
        end
    end)
end

-- ── HOTKEY ───────────────────────────────────────────────────────────────────
function VantaUI:_hotkey(key)
    UIS.InputBegan:Connect(function(i,p)
        if not p and i.KeyCode==key then self:Toggle() end
    end)
end

-- ── OPEN ANIMATION ───────────────────────────────────────────────────────────
function VantaUI:_open()
    self._win.Size=UDim2.new(1,0,0,0)
    task.wait(.04)
    tw(self._win,{Size=UDim2.new(1,0,1,0)},.42,Enum.EasingStyle.Back,Enum.EasingDirection.Out)
end

-- ── TOGGLE ───────────────────────────────────────────────────────────────────
function VantaUI:Toggle()
    self.toggled=not self.toggled
    if self.toggled then
        self._holder.Visible=true
        self._win.Size=UDim2.new(1,0,0,0)
        tw(self._win,{Size=UDim2.new(1,0,1,0)},.38,Enum.EasingStyle.Back,Enum.EasingDirection.Out)
    else
        tw(self._win,{Size=UDim2.new(1,0,0,0)},.24,Enum.EasingStyle.Quart,Enum.EasingDirection.In,function()
            self._holder.Visible=false
        end)
    end
end

-- ── ACCENT ───────────────────────────────────────────────────────────────────
function VantaUI:SetAccent(c)
    self.accent=c
    self._glow.BackgroundColor3=c
    self._ind.BackgroundColor3=c
    for _,tab in pairs(self._tabs) do
        if tab._on then tw(tab._btn,{TextColor3=c},.15) end
    end
end

-- ── TAB ──────────────────────────────────────────────────────────────────────
function VantaUI:Tab(opts)
    opts=opts or {}
    local name=opts.name or "Tab"
    local icon=opts.icon or ""
    local lib=self

    local tab={}; tab._on=false; tab._lib=lib

    local label=(icon~="" and icon.."  " or "")..name
    local bw=txsz(label,13,Enum.Font.GothamMedium).X+22

    tab._btn=mk("TextButton",{
        Size=UDim2.new(0,bw,1,0),BackgroundTransparency=1,
        Text=label,TextColor3=T.TextDim,TextSize=13,
        Font=Enum.Font.GothamMedium,AutoButtonColor=false,ZIndex=7,
    },self._tabbtns)

    tab._frame=mk("Frame",{
        Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
        Visible=false,ZIndex=3,
    },self._content)

    -- two scrollable columns
    tab._L=mk("ScrollingFrame",{
        Size=UDim2.new(.5,-7,1,-12),Position=UDim2.new(0,6,0,6),
        BackgroundTransparency=1,ScrollBarThickness=2,
        ScrollBarImageColor3=T.BorderLt,CanvasSize=UDim2.new(0,0,0,0),
        AutomaticCanvasSize=Enum.AutomaticSize.Y,BorderSizePixel=0,
    },tab._frame)
    list(Enum.FillDirection.Vertical,8,tab._L)

    tab._R=mk("ScrollingFrame",{
        Size=UDim2.new(.5,-7,1,-12),Position=UDim2.new(.5,3,0,6),
        BackgroundTransparency=1,ScrollBarThickness=2,
        ScrollBarImageColor3=T.BorderLt,CanvasSize=UDim2.new(0,0,0,0),
        AutomaticCanvasSize=Enum.AutomaticSize.Y,BorderSizePixel=0,
    },tab._frame)
    list(Enum.FillDirection.Vertical,8,tab._R)

    -- hover
    tab._btn.MouseEnter:Connect(function()
        if not tab._on then tw(tab._btn,{TextColor3=T.TextSub},.12) end
    end)
    tab._btn.MouseLeave:Connect(function()
        if not tab._on then tw(tab._btn,{TextColor3=T.TextDim},.12) end
    end)
    tab._btn.MouseButton1Click:Connect(function() lib:_switch(tab) end)

    table.insert(self._tabs,tab)
    if #self._tabs==1 then task.defer(function() lib:_switch(tab) end) end

    -- ── SECTION ──────────────────────────────────────────────────────────
    function tab:Section(so)
        so=so or {}
        local sname=so.name or "Section"
        local side=(so.side or "left"):lower()
        local col=side=="right" and self._R or self._L

        local sec={}; sec._lib=lib; sec._tab=self

        sec._wrap=mk("Frame",{
            Size=UDim2.new(1,0,0,28),BackgroundColor3=T.BG3,
            BorderSizePixel=0,AutomaticSize=Enum.AutomaticSize.Y,
        },col)
        corner(8,sec._wrap)
        stroke(T.Border,1,sec._wrap)

        -- header
        local hdr=mk("Frame",{Size=UDim2.new(1,0,0,28),BackgroundTransparency=1,ZIndex=2},sec._wrap)
        local pip=mk("Frame",{Size=UDim2.new(0,3,0,13),Position=UDim2.new(0,8,.5,-6.5),
            BackgroundColor3=lib.accent,BorderSizePixel=0,ZIndex=3},hdr)
        corner(2,pip)
        mk("TextLabel",{Size=UDim2.new(1,-20,1,0),Position=UDim2.new(0,18,0,0),
            BackgroundTransparency=1,Text=sname:upper(),TextColor3=T.TextDim,
            TextSize=10,Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=3},hdr)

        -- divider
        mk("Frame",{Size=UDim2.new(1,-16,0,1),Position=UDim2.new(0,8,0,27),
            BackgroundColor3=T.Border,BorderSizePixel=0,ZIndex=2},sec._wrap)

        sec._body=mk("Frame",{
            Size=UDim2.new(1,0,0,0),Position=UDim2.new(0,0,0,28),
            BackgroundTransparency=1,AutomaticSize=Enum.AutomaticSize.Y,ZIndex=2,
        },sec._wrap)
        list(Enum.FillDirection.Vertical,2,sec._body)
        pad(6,6,4,6,sec._body)

        -- ── helpers shared by all elements ────────────────────────────────
        local function baseRow(h)
            local r=mk("Frame",{
                Size=UDim2.new(1,0,0,h or 30),BackgroundColor3=T.BG4,
                BackgroundTransparency=.45,BorderSizePixel=0,ZIndex=3,
            },sec._body)
            corner(6,r)
            return r
        end
        local function rowHover(r)
            r.MouseEnter:Connect(function() tw(r,{BackgroundTransparency=.2},.1) end)
            r.MouseLeave:Connect(function() tw(r,{BackgroundTransparency=.45},.1) end)
        end
        local function rowLabel(r,txt,xoff)
            return mk("TextLabel",{
                Size=UDim2.new(1,-(xoff or 50),1,0),Position=UDim2.new(0,10,0,0),
                BackgroundTransparency=1,Text=txt,TextColor3=T.TextSub,
                TextSize=12,Font=Enum.Font.GothamMedium,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=4,
            },r)
        end

        -- ── TOGGLE ───────────────────────────────────────────────────────
        function sec:Toggle(o)
            o=o or {}
            local nm=o.name or "Toggle"; local ptr=o.pointer or nm
            local def=o.default or false; local cb=o.callback or function()end
            local state=def; lib.flags[ptr]=state

            local r=baseRow(30); rowHover(r)
            local lbl=rowLabel(r,nm,52)
            lbl.TextColor3=state and T.TextPri or T.TextSub

            -- pill
            local track=mk("Frame",{Size=UDim2.new(0,36,0,18),
                Position=UDim2.new(1,-44,.5,-9),
                BackgroundColor3=state and lib.accent or T.BG2,
                BorderSizePixel=0,ZIndex=4},r)
            corner(9,track)
            local tstr=stroke(state and lib.accent or T.Border,1,track)

            local thumb=mk("Frame",{
                Size=UDim2.new(0,12,0,12),
                Position=state and UDim2.new(1,-15,.5,-6) or UDim2.new(0,3,.5,-6),
                BackgroundColor3=Color3.fromRGB(255,255,255),BorderSizePixel=0,ZIndex=5},track)
            corner(6,thumb)

            local busy=false
            local function flip()
                if busy then return end; busy=true
                state=not state; lib.flags[ptr]=state
                sp(thumb,{Position=state and UDim2.new(1,-15,.5,-6) or UDim2.new(0,3,.5,-6)})
                tw(track,{BackgroundColor3=state and lib.accent or T.BG2},.18)
                tw(lbl,{TextColor3=state and T.TextPri or T.TextSub},.18)
                tw(tstr,{Color=state and lib.accent or T.Border},.18)
                tw(r,{BackgroundTransparency=.1},.08,nil,nil,function()
                    tw(r,{BackgroundTransparency=.45},.18)
                end)
                task.delay(.06,function() busy=false; cb(state) end)
            end

            local btn=mk("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=6},r)
            btn.MouseButton1Click:Connect(flip)

            local t={}
            function t:Set(v) if v~=state then flip() end end
            lib._setters[ptr]=function(v) t:Set(v) end

            function t:Colorpicker(co)
                co=co or {}
                return sec:Colorpicker(co, r)
            end
            return t
        end

        -- ── SLIDER ───────────────────────────────────────────────────────
        function sec:Slider(o)
            o=o or {}
            local nm=o.name or "Slider"; local ptr=o.pointer or nm
            local mn=o.minimum or 0; local mx=o.maximum or 100
            local dec=o.decimals or 1; local suf=o.suffix or ""
            local def=math.clamp(o.default or mn,mn,mx)
            local cb=o.callback or function()end
            local val=def; lib.flags[ptr]=val

            local r=baseRow(44); rowHover(r)

            -- top row: name + value
            mk("TextLabel",{Size=UDim2.new(.6,0,0,20),Position=UDim2.new(0,10,0,2),
                BackgroundTransparency=1,Text=nm,TextColor3=T.TextSub,
                TextSize=12,Font=Enum.Font.GothamMedium,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=4},r)
            local vlbl=mk("TextLabel",{Size=UDim2.new(.4,-10,0,20),Position=UDim2.new(.6,0,0,2),
                BackgroundTransparency=1,Text=tostring(val)..suf,TextColor3=lib.accent,
                TextSize=12,Font=Enum.Font.GothamBold,TextXAlignment=Enum.TextXAlignment.Right,ZIndex=4},r)

            -- track
            local trk=mk("Frame",{Size=UDim2.new(1,-20,0,6),Position=UDim2.new(0,10,0,28),
                BackgroundColor3=T.BG2,BorderSizePixel=0,ZIndex=4,ClipsDescendants=true},r)
            corner(3,trk)
            local fill=mk("Frame",{Size=UDim2.new((val-mn)/(mx-mn),0,1,0),
                BackgroundColor3=lib.accent,BorderSizePixel=0,ZIndex=5},trk)
            corner(3,fill)
            grad(lib.accent,T.AccentDim,0,fill)

            -- thumb
            local pct=(val-mn)/(mx-mn)
            local thm=mk("Frame",{Size=UDim2.new(0,12,0,12),
                Position=UDim2.new(pct,-6,.5,-6),
                BackgroundColor3=Color3.fromRGB(255,255,255),BorderSizePixel=0,ZIndex=6},trk)
            corner(6,thm)

            local sliding=false
            local function upd(ix)
                local rel=math.clamp((ix-trk.AbsolutePosition.X)/trk.AbsoluteSize.X,0,1)
                local f=10^dec
                val=math.floor((mn+(mx-mn)*rel)*f+.5)/f
                val=math.clamp(val,mn,mx)
                lib.flags[ptr]=val
                local p=(val-mn)/(mx-mn)
                fill.Size=UDim2.new(p,0,1,0)
                thm.Position=UDim2.new(p,-6,.5,-6)
                vlbl.Text=tostring(val)..suf
                cb(val)
            end

            local hb=mk("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=7},trk)
            hb.InputBegan:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 then
                    sliding=true; upd(i.Position.X)
                    sp(thm,{Size=UDim2.new(0,14,0,14),Position=UDim2.new((val-mn)/(mx-mn),-7,.5,-7)})
                end
            end)
            hb.InputEnded:Connect(function(i)
                if i.UserInputType==Enum.UserInputType.MouseButton1 then
                    sliding=false
                    sp(thm,{Size=UDim2.new(0,12,0,12),Position=UDim2.new((val-mn)/(mx-mn),-6,.5,-6)})
                end
            end)
            UIS.InputChanged:Connect(function(i)
                if sliding and i.UserInputType==Enum.UserInputType.MouseMovement then upd(i.Position.X) end
            end)

            local s={}
            function s:Set(v)
                val=math.clamp(v,mn,mx); lib.flags[ptr]=val
                local p=(val-mn)/(mx-mn)
                fill.Size=UDim2.new(p,0,1,0); thm.Position=UDim2.new(p,-6,.5,-6)
                vlbl.Text=tostring(val)..suf; cb(val)
            end
            lib._setters[ptr]=function(v) s:Set(v) end
            return s
        end

        return sec
    end

    return tab
end

        -- ── DROPDOWN ─────────────────────────────────────────────────────
        function sec:Dropdown(o)
            o=o or {}
            local nm=o.name or "Dropdown"; local ptr=o.pointer or nm
            local opts2=o.options or {}; local def=o.default
            local cb=o.callback or function()end
            local chosen=def; lib.flags[ptr]=chosen

            local r=baseRow(30); rowHover(r)
            rowLabel(r,nm,0)

            -- value display
            local vdisp=mk("TextLabel",{
                Size=UDim2.new(1,-10,1,0),Position=UDim2.new(0,0,0,0),
                BackgroundTransparency=1,
                Text=(chosen or "Select..."),
                TextColor3=chosen and T.TextPri or T.TextDim,
                TextSize=12,Font=Enum.Font.GothamMedium,
                TextXAlignment=Enum.TextXAlignment.Right,ZIndex=4,
            },r)

            -- arrow
            local arrow=mk("TextLabel",{
                Size=UDim2.new(0,16,1,0),Position=UDim2.new(1,-18,0,0),
                BackgroundTransparency=1,Text="▾",TextColor3=T.TextDim,
                TextSize=11,Font=Enum.Font.GothamBold,ZIndex=4,
            },r)

            -- dropdown panel (hidden by default)
            local panel=mk("Frame",{
                Size=UDim2.new(1,0,0,0),Position=UDim2.new(0,0,1,2),
                BackgroundColor3=T.BG3,BorderSizePixel=0,
                ClipsDescendants=true,ZIndex=10,Visible=false,
            },r)
            corner(6,panel); stroke(T.Border,1,panel)
            shadow(panel,12,.7)

            local plist=mk("Frame",{
                Size=UDim2.new(1,0,0,0),BackgroundTransparency=1,
                AutomaticSize=Enum.AutomaticSize.Y,ZIndex=10,
            },panel)
            list(Enum.FillDirection.Vertical,1,plist)
            pad(4,4,4,4,plist)

            local open=false
            local function close()
                open=false
                tw(arrow,{Rotation=0},.15)
                tw(panel,{Size=UDim2.new(1,0,0,0)},.18,Enum.EasingStyle.Quart,Enum.EasingDirection.In,function()
                    panel.Visible=false
                end)
            end
            local function openDD()
                open=true; panel.Visible=true
                tw(arrow,{Rotation=180},.15)
                local th=#opts2*26+8
                tw(panel,{Size=UDim2.new(1,0,0,th)},.22,Enum.EasingStyle.Back,Enum.EasingDirection.Out)
            end

            -- build options
            local optBtns={}
            for _,opt in ipairs(opts2) do
                local ob=mk("TextButton",{
                    Size=UDim2.new(1,0,0,24),BackgroundColor3=T.BG4,
                    BackgroundTransparency=opt==chosen and .2 or .8,
                    Text=opt,TextColor3=opt==chosen and T.TextPri or T.TextSub,
                    TextSize=12,Font=Enum.Font.GothamMedium,
                    AutoButtonColor=false,ZIndex=11,
                },plist)
                corner(4,ob)
                optBtns[opt]=ob
                ob.MouseEnter:Connect(function()
                    if opt~=chosen then tw(ob,{BackgroundTransparency=.5},.1) end
                end)
                ob.MouseLeave:Connect(function()
                    if opt~=chosen then tw(ob,{BackgroundTransparency=.8},.1) end
                end)
                ob.MouseButton1Click:Connect(function()
                    -- deselect old
                    if chosen and optBtns[chosen] then
                        tw(optBtns[chosen],{BackgroundTransparency=.8},.15)
                        tw(optBtns[chosen],{TextColor3=T.TextSub},.15)
                    end
                    chosen=opt; lib.flags[ptr]=opt
                    vdisp.Text=opt; vdisp.TextColor3=T.TextPri
                    tw(ob,{BackgroundTransparency=.2},.15)
                    tw(ob,{TextColor3=T.TextPri},.15)
                    close(); cb(opt)
                end)
            end

            local btn=mk("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=5},r)
            btn.MouseButton1Click:Connect(function()
                if open then close() else openDD() end
            end)

            local s={}
            function s:Set(v)
                if chosen and optBtns[chosen] then
                    tw(optBtns[chosen],{BackgroundTransparency=.8},.15)
                    tw(optBtns[chosen],{TextColor3=T.TextSub},.15)
                end
                chosen=v; lib.flags[ptr]=v
                vdisp.Text=v or "Select..."; vdisp.TextColor3=v and T.TextPri or T.TextDim
                if v and optBtns[v] then
                    tw(optBtns[v],{BackgroundTransparency=.2},.15)
                    tw(optBtns[v],{TextColor3=T.TextPri},.15)
                end
                cb(v)
            end
            lib._setters[ptr]=function(v) s:Set(v) end
            return s
        end

        -- ── KEYBIND ──────────────────────────────────────────────────────
        function sec:Keybind(o)
            o=o or {}
            local nm=o.name or "Keybind"; local ptr=o.pointer or nm
            local def=o.default; local cb=o.callback or function()end
            local bl=o.blacklist or {}
            table.insert(bl,Enum.UserInputType.Focus)

            local key=def; lib.flags[ptr]=key
            local binding=false

            local r=baseRow(30); rowHover(r)
            rowLabel(r,nm,80)

            local kdisp=mk("TextButton",{
                Size=UDim2.new(0,70,0,20),Position=UDim2.new(1,-76,.5,-10),
                BackgroundColor3=T.BG2,BackgroundTransparency=.3,
                Text=key and "["..tostring(key):gsub("Enum.KeyCode.","").."]" or "[NONE]",
                TextColor3=T.TextSub,TextSize=11,Font=Enum.Font.GothamMedium,
                AutoButtonColor=false,ZIndex=4,
            },r)
            corner(4,kdisp); stroke(T.Border,1,kdisp)

            local conn
            kdisp.MouseButton1Click:Connect(function()
                if binding then return end
                binding=true
                kdisp.Text="[...]"; kdisp.TextColor3=lib.accent
                tw(kdisp,{BackgroundTransparency=.1},.1)
                if conn then conn:Disconnect() end
                conn=UIS.InputBegan:Connect(function(i)
                    local isKey=i.UserInputType==Enum.UserInputType.Keyboard
                    local k=isKey and i.KeyCode or i.UserInputType
                    if table.find(bl,k) then return end
                    conn:Disconnect(); binding=false
                    key=k; lib.flags[ptr]=k
                    kdisp.Text="["..tostring(k):gsub("Enum.KeyCode.",""):gsub("Enum.UserInputType.","").."]"
                    kdisp.TextColor3=T.TextSub
                    tw(kdisp,{BackgroundTransparency=.3},.1)
                    cb(k)
                end)
            end)

            local s={}
            function s:Set(k)
                key=k; lib.flags[ptr]=k
                kdisp.Text=k and "["..tostring(k):gsub("Enum.KeyCode.","").."]" or "[NONE]"
                cb(k)
            end
            lib._setters[ptr]=function(v) s:Set(v) end
            return s
        end

